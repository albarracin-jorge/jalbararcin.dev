---
const startDate = new Date(2021, 8, 1); // September 2021
const currentDate = new Date();
const yearsExperience = Math.floor((currentDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24 * 365.25));
---

<section class="h-screen bg-linear-to-t from-neutral-900 to-black relative z-0 flex justify-center snap-center font-mono">
  <div class="w-1/2 bg-indigo-500 hidden md:block">
    <img src="" alt="">
  </div>
  <div class="md:w-1/2 flex items-center">
    <p class="italic text-lg px-8 md:text-2xl md:px-12">I started studying software development in 2018, bringing {yearsExperience}+ years of experience as a developer across various domains. I'm someone constantly seeking to improve and push beyond my current capabilities. I'm not afraid to experiment and try new things. I stay informed about industry trends and embrace innovation without hesitation.
      <span id="about" class="inline-block text-indigo-400 select-none align-baseline">_</span>
    </p>
  </div>
</section>

<script>
  import { animate } from "motion";

  const cursor = document.getElementById('about') as HTMLElement | null;

  // Blink the underscore cursor forever using a small loop
  if (cursor) {
    (async function blink() {
      while (true) {
        await (animate(cursor, { opacity: 0.2 }, { duration: 0.6, ease: 'easeInOut' }) as any).finished;
        await (animate(cursor, { opacity: 1 }, { duration: 0.6, ease: 'easeInOut' }) as any).finished;
      }
    })();
  }
</script>

