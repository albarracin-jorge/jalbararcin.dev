<script>
  import { animate } from 'motion';
  const text = 'Software Developer';
  const typed = document.getElementById('typed-text') as HTMLElement;
  const cursor = document.getElementById('cursor') as HTMLElement | null;

  // Blink the underscore cursor forever using a small loop
  if (cursor) {
    (async function blink() {
      while (true) {
        await (animate(cursor, { opacity: 0.2 }, { duration: 0.6, ease: 'easeInOut' }) as any).finished;
        await (animate(cursor, { opacity: 1 }, { duration: 0.6, ease: 'easeInOut' }) as any).finished;
      }
    })();
  }

  // Type the text left-to-right
  let i = 0;
  const typeNext = () => {
    if (i <= text.length) {
      typed.textContent = text.slice(0, i);
      i++;
      setTimeout(typeNext, 90);
    }
  };
  typeNext();
</script>

