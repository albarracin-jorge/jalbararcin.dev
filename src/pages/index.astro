import MainLayout from '../layout/MainLayout.astro';
---

<MainLayout>
  <section class="flex flex-col lg:flex-row items-center justify-between min-h-screen lg:pb-24 magicpattern">
    <div class="lg:ml-64">
      <h2 class="text-5xl my-4 text-indigo-200">Welcome</h2>
      <h1 class="text-7xl my-4">I'm Jorge Albarracín</h1>
      <h2 class="text-5xl my-4">Fullstack Developer_</h2>
    </div>
    <div class="lg:mr-64">
      <img class="scale-50 lg:scale-75 ring-indigo-700 ring-8 hover:mask-clip-border" src="https://avatars.githubusercontent.com/u/78957607?v=4" alt="avatar">
    </div>
  </section>
  <div class="bg-zinc-900 h-[100dvh] w-full flex">
    <div id="interval-1" class="bg-indigo-300 w-1/3"></div>
    <div id="interval-2" class="bg-indigo-500 w-1/3"></div>
    <div id="interval-3" class="bg-indigo-700 w-1/3"></div>
  </div>
  <section class="h-[100dvh] flex items-center justify-center">
    <p>about me</p>
  </section>
</MainLayout>

