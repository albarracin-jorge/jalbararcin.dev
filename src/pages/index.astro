---
import MainLayout from '../layout/MainLayout.astro';
import Welcome from '../components/Welcome.astro';
import About from '../components/About.astro';
---

<MainLayout>
  <Welcome />
  <div class="bg-zinc-900 h-[100dvh] w-full flex">
    <div id="interval-1" class="bg-indigo-200 w-1/3 relative z-10"></div>
    <div id="interval-2" class="bg-indigo-500 w-1/3 relative lg:top-48 z-10"></div>
    <div id="interval-3" class="bg-indigo-800 w-1/3 relative lg:top-96 z-10"></div>
  </div>
  <About />
</MainLayout>

<script>
  import { scroll, animate } from 'motion';

  const interval1 = document.getElementById('interval-1');
  const interval2 = document.getElementById('interval-2');
  const interval3 = document.getElementById('interval-3');
  const mouseScroll = document.getElementsByClassName('animate-bounce')[0] as HTMLElement;
  const aboutSection = document.getElementById('about');
  const welcomeSection = document.getElementById('welcome');
  let lastScrollProgress = 0;
  let isSnapping = false;
  let currentSection = 0;
  const snapThreshold = 0.10;

  scroll((progress: number) => {
    const smoothProgress = progress * 0.9 + lastScrollProgress * 0.1;
    lastScrollProgress = smoothProgress;
    
    animate(mouseScroll, { 
      opacity: Math.max(0, 1 - smoothProgress * 2) 
    }, { 
      duration: 0.3, 
      ease: 'easeOut'
    });

    const baseTranslate = -120 * smoothProgress;
    
    animate(interval1!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.3, 
      ease: 'easeOut',
    });
    
    animate(interval2!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.5, 
      ease: 'easeOut'
    });
    
    animate(interval3!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.7, 
      ease: 'easeOut'
    });
  });
</script>

