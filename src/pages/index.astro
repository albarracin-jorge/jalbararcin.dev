---
import MainLayout from '../layout/MainLayout.astro';
---

<MainLayout>
  <section id="welcome" class="flex flex-col h-screen items-center mb-24 magicpattern snap-center">
    <div class="flex lg:flex-row items-center gap-24 lg:mt-64">
      <div class="">
        <h2 class="text-5xl my-4 text-indigo-400">Welcome</h2>
        <h1 class="text-7xl my-4">I'm Jorge Albarracín</h1>
        <h2 class="text-5xl my-4">Fullstack Developer_</h2>
      </div>
      <div class="">
        <img class="scale-50 lg:scale-75 ring-indigo-700 ring-4 transition-all hover:rotate-[5deg] hover:ring-8" src="https://avatars.githubusercontent.com/u/78957607?v=4" alt="avatar">
      </div>
    </div>
    <div class="animate-bounce mt-32">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" color="#7c86ff" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mouse-icon lucide-mouse"><rect x="5" y="2" width="14" height="20" rx="7"/><path d="M12 6v4"/></svg>
    </div>
  </section>
  <div class="bg-zinc-900 h-[100dvh] w-full flex">
    <div id="interval-1" class="bg-indigo-200 w-1/3 relative z-10"></div>
    <div id="interval-2" class="bg-indigo-500 w-1/3 relative top-48 z-10"></div>
    <div id="interval-3" class="bg-indigo-800 w-1/3 relative top-96 z-10"></div>
  </div>
  <section id="about" class="h-screen mt-[-100vh] bg-zinc-950 relative z-0 flex items-center justify-center snap-center">
    <p>about me</p>
  </section>
</MainLayout>

<script>
  import { scroll, animate } from 'motion';

  const interval1 = document.getElementById('interval-1');
  const interval2 = document.getElementById('interval-2');
  const interval3 = document.getElementById('interval-3');
  const mouseScroll = document.getElementsByClassName('animate-bounce')[0] as HTMLElement;
  const aboutSection = document.getElementById('about');
  const welcomeSection = document.getElementById('welcome');
  let lastScrollProgress = 0;
  let isSnapping = false;
  let currentSection = 0;
  const snapThreshold = 0.10;

  scroll((progress: number) => {
    const smoothProgress = progress * 0.9 + lastScrollProgress * 0.1;
    lastScrollProgress = smoothProgress;
    
    animate(mouseScroll, { 
      opacity: Math.max(0, 1 - smoothProgress * 2) 
    }, { 
      duration: 0.3, 
      ease: 'easeOut'
    });

    const baseTranslate = -120 * smoothProgress;
    
    animate(interval1!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.3, 
      ease: 'easeOut',
    });
    
    animate(interval2!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.5, 
      ease: 'easeOut'
    });
    
    animate(interval3!, { 
      transform: `translateY(${baseTranslate}%)`,
      top: 0
    }, { 
      duration: 0.7, 
      ease: 'easeOut'
    });


    // // Handle section transitions more smoothly
    // if (smoothProgress > 0.99 && !isTransitioning) {
    //   isTransitioning = true;
    //   // Gentle transition to about section
    //   setTimeout(() => {
    //     aboutSection?.scrollIntoView({ 
    //       behavior: 'smooth',
    //       block: 'start'
    //     });
    //     setTimeout(() => {
    //       isTransitioning = false;
    //     }, 800);
    //   }, 200);
    // }

    // // Handle returning to welcome section
    // if (smoothProgress < 0.001 && !isTransitioning && window.scrollY > 0) {
    //   isTransitioning = true;
    //   setTimeout(() => {
    //     welcomeSection?.scrollIntoView({ 
    //       behavior: 'smooth',
    //       block: 'start'
    //     });
    //     setTimeout(() => {
    //       isTransitioning = false;
    //     }, 800);
    //   }, 200);
    // }
  });

  // let ticking = false;
  // window.addEventListener('scroll', () => {
  //   if (!ticking) {
  //     requestAnimationFrame(() => {
  //       const scrollTop = window.scrollY;
  //       const windowHeight = window.innerHeight;
  //       const progress = Math.min(scrollTop / windowHeight, 1);
        
  //       // Apply scroll progress with smooth easing
  //       if (!isTransitioning) {
  //         lastScrollProgress = progress;
  //       }
  //       ticking = false;
