---
import SocialMedia from "../components/Layout/SocialMedia.astro";
import LoadingScreen from "../components/LoadingScreen.astro";
import linkedInLogo from "../assets/linkedin.svg";
import gitHubLogo from "../assets/github.svg";
import "../styles/global.css";

const linkedin = "https://www.linkedin.com/in/jorge-albarracin/";
const github = "https://github.com/albarracin-jorge";
---

<!doctype html>
<html lang="en" class="dark snap-y snap-mandatory scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			property="og:title"
			content="JAlbarracín | Desarrollador Full Stack"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://jalbarracin.dev" />
		<meta
			property="og:description"
			content="Bienvenido a mi sitio web, aquí encontraras información sobre mi carrerra profesional."
		/>
		<meta
			property="og:image"
			content="https://jalbarracin.dev/jalbarracin-website-social.png"
		/>
		<meta
			property="og:image:alt"
			content="JAlbarracín | Desarrollador Full Stack"
		/>
    <meta name="description" content="Welcome to Jorge Albarracin website, here you will find information about my professional career." />
		<link rel="shortcut icon" href="favicon.svg" type="image/x-icon" />
		<title>Albarracín Jorge | Developer</title>
	</head>
	<body class="dark:bg-zinc-950 dark:text-slate-100 flex flex-col">
		<LoadingScreen />
		<slot />
	</body>
</html>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Nothing+You+Could+Do&display=swap");
	@import url("https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap");

	body {
		font-family: "Open Sans", sans-serif;
	}

</style>
